# ── Valora Bot config ──

# Operating mode: observe (read-only, no writes) | active (writes enabled)
MODE=observe
# Global dry-run: when true, risky writes are simulated, never sent
DRY_RUN=true

# Base URL (rarely changes)
VALORA_BASE=https://valora.gg/play

# ── Wallets (multi-wallet) ──
# Either a JSON array (inline) OR point to data/wallets.json
# Each: {"label":"main","key":"<base58 secret OR [json array]>","telegramTag":"@you"}
# WALLETS=[{"label":"main","key":"BASE58_SECRET_KEY"}]
WALLETS_FILE=data/wallets.json

# ── Telegram (owner-only) ──
TELEGRAM_BOT_TOKEN=
# Comma-separated owner chat IDs allowed to control the bot
TELEGRAM_OWNER_IDS=

# ── Solana ──
# Cluster used for token tx encoding (mainnet-beta | devnet | testnet)
SOLANA_CLUSTER=mainnet-beta

# ── Anti-ban pacing (ms) ──
ACTION_MIN_DELAY=800
ACTION_MAX_DELAY=2600
RECONNECT_MIN_MS=2000
RECONNECT_MAX_MS=15000

# ── Fallback captcha solver (only if a challenge appears later) ──
TWOCAPTCHA_API_KEY=
